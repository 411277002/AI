# server
PORT=3001

# Gemini 文字生成
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEYS=
GEMINI_API_KEY=

# 開發用 AI mock mode
# true = 不呼叫 Gemini，只回傳 RAG mock 測試結果
# false = 使用正式 Gemini API
AI_MOCK_MODE=true

# Cloudflare Workers AI / Stable Diffusion
# 本機開發時使用 http://127.0.0.1:8787
# 部署後可改成 https://your-worker.your-subdomain.workers.dev
CLOUDFLARE_IMAGE_WORKER_URL=http://127.0.0.1:8787

# 可選：舊版 Gemini 圖片生成 API 會用到。
# 不填時程式會預設使用 models/gemini-2.5-flash-image。
GEMINI_IMAGE_MODEL=models/gemini-2.5-flash-image
USE_MOCK_IMAGE=false

# 資料庫
# 請在 backend/.env 放入自己的真實連線字串，不要把密碼 commit 上去。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT
JWT_SECRET="change-this-local-dev-secret"
