generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  userName     String   @unique
  passwordSalt String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Case {
  id          String   @id
  title       String
  label       String
  description String
  genre       Json
  tags        Json
  version     String
  bannerImage String
  coverImage  String
  story       Json
  mock        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GameNote {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model CaseReport {
  id               String   @id @default(cuid())
  userId           String
  caseId           String
  gameId           String?
  caseTitle        String
  playerRoleId     String?
  playerRoleName   String?
  playerRole       String?
  accusedNpcId     String?
  accusedNpcName   String?
  accusedNpcRole   String?
  killerNpcId      String?
  killerNpcName    String?
  correct          Boolean
  reason           String   @default("")
  report           String
  evidenceSnapshot Json
  npcSnapshot      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([caseId])
  @@index([gameId])
  @@index([createdAt])
}
